{
  "name": "artist-gallery",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/generate-seo.mjs",
    "preview": "vite preview",
    "deploy:yc": "bash scripts/deploy-yc.sh",
    "upload:media": "node scripts/generate-thumbs.mjs && bash scripts/upload-media.sh",
    "upload:media:files": "bash scripts/upload-media-files.sh",
    "import:desktop": "bash scripts/import-desktop.sh",
    "sync:desktop": "node scripts/sync-from-desktop.mjs",
    "thumbs": "node scripts/generate-thumbs.mjs",
    "seo:notify-yandex": "node scripts/notify-yandex-indexnow.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
